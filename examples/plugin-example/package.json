{
  "name": "@uniview/example-plugin",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build.ts",
    "dev": "bun build.ts --serve",
    "client": "bun build.ts && run-p client:simple client:advanced",
    "client:simple": "bun dist/simple-demo.client.js",
    "client:advanced": "bun dist/advanced-demo.client.js",
    "client:benchmark-full": "bun dist/benchmark-full.client.js",
    "client:benchmark-incremental": "bun dist/benchmark-incremental.client.js",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@uniview/example-plugin-api": "workspace:*",
    "@uniview/react-runtime": "workspace:*",
    "is-what": "^5.5.0",
    "react": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/react": "^19.0.0",
    "npm-run-all2": "^8.0.4"
  }
}
