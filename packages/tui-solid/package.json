{
  "name": "@uniview/tui-solid",
  "type": "module",
  "version": "0.0.1",
  "description": "Render Solid plugins to the terminal via @uniview/host-tui and @uniview/tui-core",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@uniview/host-tui": "workspace:*",
    "@uniview/solid-renderer": "workspace:*",
    "@uniview/tui-core": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@types/node": "^22.0.0",
    "babel-preset-solid": "^1.9.0",
    "solid-js": "^1.9.9",
    "tsdown": "0.22.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
