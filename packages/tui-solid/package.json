{
  "name": "@uniview/tui-solid",
  "type": "module",
  "version": "0.0.1",
  "description": "Render Solid components to the terminal",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HuakunShen/uniview.git",
    "directory": "packages/tui-solid"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@uniview/tui-core": "workspace:*",
    "lowlight": "^3.3.0",
    "marked": "^15.0.0"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "optionalDependencies": {
    "solid-devtools": "^0.34.5"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@uniview/host-tui": "workspace:*",
    "@uniview/protocol": "workspace:*",
    "@uniview/solid-renderer": "workspace:*",
    "@uniview/style": "workspace:*",
    "@uniview/tui-charts": "workspace:*",
    "@uniview/tui-content": "workspace:*",
    "@uniview/tui-react": "workspace:*",
    "babel-preset-solid": "^1.9.0",
    "react": "catalog:",
    "solid-js": "^1.9.9",
    "tsdown": "0.22.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
