{
  "name": "@uniview/react-runtime",
  "type": "module",
  "version": "0.0.1",
  "description": "React plugin-side runtime for the Uniview plugin system",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.mjs",
    "./ws-client": "./dist/ws-client.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@uniview/protocol": "workspace:*",
    "@uniview/react-renderer": "workspace:*",
    "kkrpc": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "react": "catalog:",
    "tsdown": "0.22.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
