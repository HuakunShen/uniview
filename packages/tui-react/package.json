{
  "name": "@uniview/tui-react",
  "type": "module",
  "version": "0.0.1",
  "description": "Render React components to the terminal",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HuakunShen/uniview.git",
    "directory": "packages/tui-react"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./compat": "./dist/compat.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@uniview/tui-core": "workspace:*",
    "lowlight": "^3.3.0",
    "marked": "^15.0.0",
    "react-reconciler": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "optionalDependencies": {
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@uniview/host-tui": "workspace:*",
    "@uniview/protocol": "workspace:*",
    "@uniview/react-renderer": "workspace:*",
    "@uniview/style": "workspace:*",
    "@uniview/tui-charts": "workspace:*",
    "@uniview/tui-content": "workspace:*",
    "react": "catalog:",
    "tsdown": "0.22.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
